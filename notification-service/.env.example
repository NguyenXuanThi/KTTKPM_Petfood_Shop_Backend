NODE_ENV=development
NOTIFICATION_PORT=3010
NOTIFICATION_CORS_ORIGIN=*

# Replace these with your Gmail address and Gmail App Password before sending email.
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_ALLOWED_RECIPIENT=your_gmail@gmail.com

KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=petfood-notification-service
KAFKA_DEBUG_LOG=false


KAFKA_CONSUMER_RETRY_DELAY_MS=5000
